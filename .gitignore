# --- SentinelFIM local runtime data ---
# These are generated by `sentinel.py init` / `sentinel.py monitor` inside
# whatever folder you point --path at. They are machine-specific snapshots
# and backups, not source code, so they should never be committed.
.baseline.json
.backup/
.quarantine/
